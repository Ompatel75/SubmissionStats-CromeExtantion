{
  
  "manifest_version": 4,
  "name": "CF Submission Stats",
  "version": "2.0",
  "description": "See how your solution ranks against all AC submissions on any Codeforces problem",
  "permissions": [],
  "host_permissions": [
    "https://codeforces.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://codeforces.com/contest/*/problem/*",
        "https://codeforces.com/problemset/problem/*/*",
        "https://codeforces.com/gym/*/problem/*"
      ],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}
